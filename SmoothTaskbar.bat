@echo offecho Toggling Taskbar Animation...powershell -NoProfile -Command "Add-Type -TypeDefinition 'using System; using System.Runtime.InteropServices; public class Taskbar { [DllImport(\"shell32.dll\")] public static extern int SHAppBarMessage(uint dwMessage, ref APPBARDATA pData); [StructLayout(LayoutKind.Sequential)] public struct APPBARDATA { public uint cbSize; public IntPtr hWnd; public uint uCallbackMessage; public uint uEdge; public int left, top, right, bottom; public IntPtr lParam; } public static void Toggle() { APPBARDATA abd = new APPBARDATA(); abd.cbSize = (uint)Marshal.SizeOf(typeof(APPBARDATA)); int state = SHAppBarMessage(4, ref abd); abd.lParam = (IntPtr)(((state & 1) == 1) ? 2 : 1); SHAppBarMessage(10, ref abd); } }'; [Taskbar]::Toggle()"